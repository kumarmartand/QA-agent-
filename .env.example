# ── AI Provider Keys (use ONE) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Test Credentials ─────────────────────────────────────────────────────────
# Referenced in YAML config as ${QA_USERNAME}, ${QA_PASSWORD}
QA_USERNAME=testuser@example.com
QA_PASSWORD=TestPassword123!

# Admin / second login role
QA_ADMIN_USER=admin@example.com
QA_ADMIN_PASS=AdminPassword123!

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (MVP default)
DATABASE_URL=

# ── Application ───────────────────────────────────────────────────────────────
QA_ENV=development                  # development | production
QA_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
QA_OUTPUT_DIR=outputs
